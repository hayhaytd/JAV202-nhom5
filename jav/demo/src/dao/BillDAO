import java.sql.*;
import java.util.*;

public class BillDAO {

    // Lấy tất cả hóa đơn
    public List<Bill> findAll() {
        List<Bill> list = new ArrayList<>();
        String sql = "SELECT * FROM Bill";

        try (Connection con = DBConnection.getConnection();
             PreparedStatement ps = con.prepareStatement(sql);
             ResultSet rs = ps.executeQuery()) {

            while (rs.next()) {
                Bill b = new Bill(
                        rs.getInt("id"),
                        rs.getString("code"),
                        rs.getTimestamp("created_at"),
                        rs.getDouble("total"),
                        rs.getInt("status"),
                        rs.getInt("user_id")
                );
                list.add(b);
            }

        } catch (Exception e) {
            e.printStackTrace();
        }

        return list;
    }

    // Thêm hóa đơn
    public int insert(Bill b) {
        String sql = "INSERT INTO Bill(code, created_at, total, status, user_id) VALUES(?,?,?,?,?)";

        try (Connection con = DBConnection.getConnection();
             PreparedStatement ps = con.prepareStatement(sql, Statement.RETURN_GENERATED_KEYS)) {

            ps.setString(1, b.getCode());
            ps.setTimestamp(2, new Timestamp(b.getCreatedAt().getTime()));
            ps.setDouble(3, b.getTotal());
            ps.setInt(4, b.getStatus());
            ps.setInt(5, b.getUserId());

            ps.executeUpdate();

            // lấy id vừa insert
            ResultSet rs = ps.getGeneratedKeys();
            if (rs.next()) {
                return rs.getInt(1);
            }

        } catch (Exception e) {
            e.printStackTrace();
        }

        return -1;
    }

    // Update trạng thái (ví dụ: thanh toán)
    public void updateStatus(int id, int status) {
        String sql = "UPDATE Bill SET status=? WHERE id=?";

        try (Connection con = DBConnection.getConnection();
             PreparedStatement ps = con.prepareStatement(sql)) {

            ps.setInt(1, status);
            ps.setInt(2, id);
            ps.executeUpdate();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    // Update total
    public void updateTotal(int id, double total) {
        String sql = "UPDATE Bill SET total=? WHERE id=?";

        try (Connection con = DBConnection.getConnection();
             PreparedStatement ps = con.prepareStatement(sql)) {

            ps.setDouble(1, total);
            ps.setInt(2, id);
            ps.executeUpdate();

        } catch (Exception e) {
            e.printStackTrace();
        }
    }

    // Tìm theo id
    public Bill findById(int id) {
        String sql = "SELECT * FROM Bill WHERE id=?";

        try (Connection con = DBConnection.getConnection();
             PreparedStatement ps = con.prepareStatement(sql)) {

            ps.setInt(1, id);
            ResultSet rs = ps.executeQuery();
if (rs.next()) {
                return new Bill(
                        rs.getInt("id"),
                        rs.getString("code"),
                        rs.getTimestamp("created_at"),
                        rs.getDouble("total"),
                        rs.getInt("status"),
                        rs.getInt("user_id")
                );
            }

        } catch (Exception e) {
            e.printStackTrace();
        }

        return null;
    }
}